NODE_ENV=development
PORT=4010
FRONTEND_URL=http://localhost:8100
FRONTEND_URLS=http://localhost:8100,http://localhost:8101
FRONTEND_URL_PATTERNS=http://*:8100,https://*.tudominio.com

DB_HOST=localhost
DB_PORT=5432
DB_NAME=computron
DB_USER=postgres
DB_PASSWORD=root12345
DB_SSL=false

JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_DAYS=7
RECEIPT_TOKEN_ENCRYPTION_KEY=replace_with_secure_receipt_token_key

SMTP_HOST=smtp.hostgator.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario_smtp
SMTP_PASS=password_smtp
SMTP_FROM=no-reply@tudominio.com

PERMISSION_CACHE_TTL_MS=30000
RESPONSE_CACHE_TTL_MS=900000
RESPONSE_CACHE_MAX_ENTRIES=500
NOTIFICATION_WORKER_CONCURRENCY=5
NOTIFICATION_WORKER_MAX_QUEUE=200
